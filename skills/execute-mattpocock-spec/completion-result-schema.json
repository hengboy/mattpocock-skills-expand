{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mattpocock/skills/execute-mattpocock-spec/completion-result.schema.json",
  "title": "execute-mattpocock-spec Completion Result",
  "description": "Completion Adapter 返回给编排器的单个 Ticket 终态结果。",
  "type": "object",
  "required": ["ticket_id", "status", "commits", "tests", "summary"],
  "additionalProperties": false,
  "properties": {
    "ticket_id": {
      "type": "string",
      "minLength": 1,
      "description": "此终态结果所属的 Ticket ID。"
    },
    "status": {
      "type": "string",
      "enum": ["done", "blocked"]
    },
    "commits": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "已运行测试的记录；空数组表示 TESTS: none。"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "error": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "done" } }, "required": ["status"] },
      "then": {
        "properties": {
          "commits": { "type": "array", "minItems": 1 }
        },
        "not": {
          "required": ["error"],
          "properties": {
            "error": true
          }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "blocked" } }, "required": ["status"] },
      "then": {
        "required": ["error"],
        "properties": {
          "commits": { "type": "array", "maxItems": 0 }
        }
      }
    }
  ]
}
